# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — only needed for running scripts/seed-supabase.ts
# Never expose this in client-side code or commit it
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Vault — the WW WhatsApp Business number users are directed to after signup
# Format: country code + number, no + or spaces (e.g. 919876543210 for +91 98765 43210)
NEXT_PUBLIC_WW_WHATSAPP=

# Anthropic API key — used server-side only for Stay Verification AI analysis
# Get yours at console.anthropic.com → API Keys
# Never prefix with NEXT_PUBLIC_ — must stay server-side only
ANTHROPIC_API_KEY=

# Site URL — used for absolute URLs in sitemap, robots.txt, and OpenGraph images
# Local: http://localhost:3000  |  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# Admin email — the Supabase account email that can access /admin moderation queue
# Set this to your own email address
ADMIN_EMAIL=

# Google Places API key — used CLIENT-SIDE for the location autocomplete on the
# beware report submission form. Get one at console.cloud.google.com:
#   1. Create a project
#   2. APIs & Services → Library → enable "Places API (New)"
#   3. APIs & Services → Credentials → Create API key
#   4. Restrict the key:
#      - Application restrictions: HTTP referrers → add your production domain
#        + http://localhost:8888/* for local dev
#      - API restrictions: Restrict to "Places API (New)" only
# Without this set, the form falls back to plain text inputs (still submittable,
# just no map pins for new submissions).
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Google Maps Geocoding API key — used SERVER-SIDE only by
# scripts/backfill-beware-gps.ts to retrofit lat/lng on legacy beware reports
# that have a text location but no coordinates. Optional — Nominatim is the
# free fallback. Should be a SEPARATE key from the Places key above, restricted
# to "Geocoding API" and either no application restrictions or IP-based.
GOOGLE_MAPS_API_KEY=

# Cron secret — optional. Lets you trigger /api/cron/weekly-digest manually
# with `Authorization: Bearer <CRON_SECRET>`. Vercel Cron itself is
# authenticated via the x-vercel-cron header and does not need this.
CRON_SECRET=

# Unsubscribe HMAC secret — used to sign the one-click unsubscribe tokens
# embedded in transactional emails. Min 16 chars in production. If unset,
# a dev-only fallback is used (do NOT ship to production unset).
UNSUBSCRIBE_SECRET=

# Fingerprint salt — optional. Salts the IP+UA hash used by /api/track-view
# to dedup anonymous intel-card views. If unset, UNSUBSCRIBE_SECRET is used;
# if both are unset, anonymous dedup is skipped (authenticated views still
# count). Must be a server-only secret — never prefix with NEXT_PUBLIC_.
FINGERPRINT_SALT=
